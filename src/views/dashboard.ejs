                        <td><label class="switch"><input type="checkbox" data-route-enabled checked disabled /><span class="switch-slider" aria-hidden="true"></span></label></td>
                      </tr>
                      <tr data-route-row data-method="GET" data-search="GET /api/whatsapp/state whatsapp state" >
                        <td><span class="badge badge-outline">GET</span></td>
                        <td class="route-path">/api/whatsapp/state</td>
                        <td>WhatsApp connection state</td>
                        <td>
                          <select class="route-visibility-select" data-route-visibility disabled>
                            <option value="public" selected>Public</option>
                            <option value="internal">Internal</option>
                          </select>
                        </td>
                        <td><label class="switch"><input type="checkbox" data-route-enabled checked disabled /><span class="switch-slider" aria-hidden="true"></span></label></td>
                      </tr>
                      <tr data-route-row data-method="POST" data-search="POST /api/schedules create schedule" >
                        <td><span class="badge badge-outline">POST</span></td>
                        <td class="route-path">/api/schedules</td>
                        <td>Create a schedule item</td>
