                        <th>Path</th>
                        <th>Purpose</th>
                        <th>Visibility</th>
                        <th>Enabled</th>
                      </tr>
                    </thead>
                    <tbody id="routeListTableBody">
                      <tr data-route-row data-method="GET" data-search="GET / dashboard home" >
                        <td><span class="badge badge-outline">GET</span></td>
                        <td class="route-path">/</td>
                        <td>Dashboard home</td>
                        <td>
                          <select class="route-visibility-select" data-route-visibility disabled>
                            <option value="public" selected>Public</option>
                            <option value="internal">Internal</option>
                          </select>
                        </td>
                        <td><label class="switch"><input type="checkbox" data-route-enabled checked disabled /><span class="switch-slider" aria-hidden="true"></span></label></td>
                      </tr>
                      <tr data-route-row data-method="GET" data-search="GET /schedule/create public schedule form" >
                        <td><span class="badge badge-outline">GET</span></td>
                        <td class="route-path">/schedule/create</td>
                        <td>Public schedule form</td>
                        <td>
