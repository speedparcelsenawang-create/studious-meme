                </div>
              </div>
            </article>
          </section>
        </div>
      </main>
    </div>

    <div class="modal" id="commandPreviewModal" hidden>
      <div class="modal-backdrop" data-close-modal="command-preview"></div>
      <div class="modal-panel command-preview-panel" role="dialog" aria-modal="true" aria-labelledby="commandPreviewTitle">
        <button type="button" class="modal-close" id="closeCommandPreviewModal" aria-label="Close preview">&times;</button>
        <div class="command-preview-viewport" id="commandPreviewViewport">
          <article class="wa-preview-card">
            <div class="wa-status-bar">
              <span class="wa-status-time">2:15 PM</span>
              <div class="wa-status-icons" aria-hidden="true">
                <span>◖◗</span>
                <span>◉</span>
                <span>▂▄▆</span>
              </div>
            </div>

            <header class="wa-chat-header">
              <span class="wa-back-icon" aria-hidden="true">&#x2039;</span>
              <div class="wa-preview-avatar">S</div>
              <div class="wa-preview-meta">
                <p class="wa-preview-name" id="commandPreviewTitle">Command Preview</p>
                <p class="wa-preview-status" id="commandPreviewDescription">online</p>
              </div>
              <div class="wa-header-actions" aria-hidden="true">
                <span>&#128222;</span>
                <span>&#128206;</span>
                <span>&#8942;</span>
              </div>
              <span class="badge badge-outline wa-preview-badge" id="commandPreviewBadge">TEXT</span>
            </header>

            <div class="wa-chat-window">
              <div class="wa-chat-conversation">
                <div class="wa-date-chip" id="commandPreviewDateChip">Today</div>

                <div class="wa-user-bubble">
                  <p class="wa-user-text" id="commandPreviewIncomingText">!command</p>
                  <span class="wa-incoming-time" id="commandPreviewIncomingTime">12:00</span>
                </div>

                <div class="wa-preview-bubble">
                <div id="commandPreviewMeta" class="command-preview-meta" hidden></div>

                <div class="command-preview-cover-wrap">
                  <img src="https://avatar.vercel.sh/shadcn1" alt="Command cover" class="command-preview-cover" id="commandPreviewImage" />
                  <video id="commandPreviewVideo" class="command-preview-media" controls hidden></video>
                  <audio id="commandPreviewAudio" class="command-preview-audio" controls hidden></audio>
                  <div id="commandPreviewDocument" class="command-preview-document" hidden>
                    <span class="badge badge-outline">Document</span>
                    <a id="commandPreviewDocumentLink" href="#" target="_blank" rel="noopener">Open document</a>
                  </div>
                </div>

                <p id="commandPreviewContent" class="command-preview-content" hidden>No content</p>

                <p id="commandPreviewDeliveryHint" class="command-preview-delivery-hint" hidden></p>

                <div id="commandPreviewButtons" class="command-preview-buttons" hidden></div>
                <span class="wa-preview-time" id="commandPreviewOutgoingTime">12:00 ✓✓</span>
                </div>
              </div>

              <div class="wa-composer" aria-hidden="true">
                <div class="wa-composer-icon">&#9786;</div>
                <div class="wa-composer-input">Type a message</div>
                <div class="wa-composer-icon">&#128206;</div>
                <button type="button" class="wa-composer-send" id="commandPreviewActionBtn">Close Preview</button>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>

    <div class="modal" id="scheduleViewModal" hidden>
      <div class="modal-backdrop" data-close-modal="schedule-view"></div>
      <div class="modal-panel schedule-view-modal-panel" role="dialog" aria-modal="true" aria-labelledby="scheduleViewModalTitle">
        <button type="button" class="modal-close" id="closeScheduleViewModal" aria-label="Close schedule details">&times;</button>
        <article class="schedule-detail-card schedule-detail-card-sm">
          <header class="card-header schedule-detail-head">
            <div>
              <h3 class="card-title" id="scheduleViewModalTitle">Schedule Details</h3>
              <p class="card-description" id="scheduleViewModalDescription">Compact detail view for this schedule item.</p>
            </div>
            <span class="badge badge-outline" id="scheduleModalStatusPill">-</span>
          </header>

          <div class="card-content schedule-detail-body">
            <div class="schedule-modal-grid">
              <p class="schedule-modal-row"><span class="schedule-modal-label">ID</span><span class="schedule-modal-value" id="scheduleModalId">-</span></p>
              <p class="schedule-modal-row"><span class="schedule-modal-label">Type</span><span class="schedule-modal-value" id="scheduleModalType">-</span></p>
              <p class="schedule-modal-row"><span class="schedule-modal-label">Target</span><span class="schedule-modal-value schedule-modal-mono" id="scheduleModalTarget">-</span></p>
              <p class="schedule-modal-row"><span class="schedule-modal-label">Time</span><span class="schedule-modal-value" id="scheduleModalTime">-</span></p>
              <p class="schedule-modal-row"><span class="schedule-modal-label">Status</span><span class="schedule-modal-value" id="scheduleModalStatus">-</span></p>
              <p class="schedule-modal-row"><span class="schedule-modal-label">Repeat</span><span class="schedule-modal-value" id="scheduleModalRepeat">-</span></p>
              <p class="schedule-modal-row schedule-modal-row-message"><span class="schedule-modal-label">Message</span><span class="schedule-modal-value" id="scheduleModalMessage">-</span></p>
              <p class="schedule-modal-row schedule-modal-row-message" id="scheduleModalMediaRow" hidden><span class="schedule-modal-label">Media</span><span class="schedule-modal-value" id="scheduleModalMedia">-</span></p>
            </div>
            <p class="feedback" id="scheduleModalFeedback"></p>
          </div>

          <footer class="schedule-modal-actions schedule-detail-footer">
            <button type="button" class="btn btn-outline" id="scheduleModalCloseBtn">Close</button>
            <button type="button" class="btn btn-outline btn-delete-modal" id="scheduleModalDeleteBtn">Delete Schedule</button>
          </footer>
        </article>
      </div>
    </div>

    <div class="modal" id="destructiveConfirmModal" hidden>
      <div class="modal-backdrop" data-close-modal="destructive-confirm"></div>
      <div
        class="modal-panel destructive-confirm-modal-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="destructiveConfirmTitle"
        aria-describedby="destructiveConfirmDescription"
      >
        <div class="alert-dialog-header">
          <span class="alert-dialog-media" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
              <path d="M10 11v6M14 11v6"></path>
              <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
            </svg>
          </span>
          <h3 class="card-title" id="destructiveConfirmTitle">Delete item?</h3>
          <p class="alert-dialog-description" id="destructiveConfirmDescription">This action cannot be undone.</p>
        </div>
        <div class="alert-dialog-footer">
          <button type="button" class="btn btn-outline" id="destructiveConfirmCancelBtn">Cancel</button>
          <button type="button" class="btn btn-delete-modal" id="destructiveConfirmActionBtn">Delete</button>
        </div>
      </div>
    </div>

    <div class="modal" id="builtInCommandModal" hidden>
      <div class="modal-backdrop" data-close-modal="builtin-command"></div>
      <div class="modal-panel schedule-view-modal-panel command-editor-modal-panel" role="dialog" aria-modal="true" aria-labelledby="builtInEditorTitle">
        <button type="button" class="modal-close" id="closeBuiltInCommandModal" aria-label="Close built-in editor">&times;</button>
        <header class="card-header schedule-detail-header">
          <h3 class="card-title" id="builtInEditorTitle">Edit Built-in Command</h3>
          <p class="card-description" id="builtInEditorDescription">Update built-in command text and behavior.</p>
        </header>
        <div class="card-content schedule-detail-body">
          <div class="command-detail-popover-editor command-editor-modal-body">
            <div id="builtInEditorButtonsSection" hidden>
              <div class="command-detail-popover-actions command-detail-popover-inline-actions">
                <button type="button" class="btn btn-ghost btn-sm" id="builtInEditorAddButtonBtn">Add Button</button>
              </div>
              <div id="builtInEditorButtonRows" class="button-rows"></div>
            </div>
            <label for="builtInEditorText" id="builtInEditorTextLabel">Response text</label>
            <textarea id="builtInEditorText" rows="8"></textarea>
            <p class="feedback" id="builtInEditorFeedback"></p>
          </div>
        </div>
        <footer class="schedule-modal-actions schedule-detail-footer">
          <button type="button" class="btn btn-outline" id="builtInEditorCancelBtn">Cancel</button>
          <button type="button" class="btn btn-outline" id="builtInEditorSaveBtn">Save</button>
        </footer>
      </div>
    </div>

    <div class="modal" id="commandDetailModal" hidden>
      <div class="modal-backdrop" data-close-modal="command-detail"></div>
      <div class="modal-panel schedule-view-modal-panel command-editor-modal-panel" role="dialog" aria-modal="true" aria-labelledby="commandDetailModalTitle">
        <button type="button" class="modal-close" id="closeCommandDetailModal" aria-label="Close command details">&times;</button>
        <header class="card-header schedule-detail-header">
          <h3 class="card-title" id="commandDetailModalTitle">Command Details</h3>
          <p class="card-description" id="commandDetailModalDescription">View response, media, and buttons for this command.</p>
        </header>
        <div class="card-content schedule-detail-body">
          <div class="command-detail-popover-editor command-editor-modal-body">
            <p class="schedule-modal-row"><span class="schedule-modal-label">Trigger</span><span class="schedule-modal-value" id="commandDetailTriggerValue">-</span></p>
            <p class="schedule-modal-row"><span class="schedule-modal-label">Source</span><span class="schedule-modal-value" id="commandDetailSourceValue">-</span></p>
            <p class="schedule-modal-row"><span class="schedule-modal-label">Media</span><span class="schedule-modal-value" id="commandDetailMediaValue">-</span></p>
            <p class="schedule-modal-row"><span class="schedule-modal-label">Buttons</span><span class="schedule-modal-value" id="commandDetailButtonsValue">-</span></p>
            <p class="schedule-modal-row schedule-modal-row-message"><span class="schedule-modal-label">Response</span><span class="schedule-modal-value" id="commandDetailResponseValue">-</span></p>
          </div>
        </div>
        <footer class="schedule-modal-actions schedule-detail-footer">
          <button type="button" class="btn btn-outline" id="commandDetailCloseBtn">Close</button>
        </footer>
      </div>
    </div>

    <div class="modal" id="customCommandEditModal" hidden>
      <div class="modal-backdrop" data-close-modal="custom-command-edit"></div>
      <div class="modal-panel schedule-view-modal-panel command-editor-modal-panel" role="dialog" aria-modal="true" aria-labelledby="customCommandEditorTitle">
        <button type="button" class="modal-close" id="closeCustomCommandEditModal" aria-label="Close custom command editor">&times;</button>
        <header class="card-header schedule-detail-header">
          <h3 class="card-title" id="customCommandEditorTitle">Edit Custom Command</h3>
          <p class="card-description" id="customCommandEditorDescription">Edit response, media, and buttons for this custom command.</p>
        </header>
        <div class="card-content schedule-detail-body">
          <input type="hidden" id="customCommandEditOriginalTrigger" />
          <div class="command-detail-popover-editor command-editor-modal-body">
            <label for="customCommandEditTrigger">Trigger</label>
            <input id="customCommandEditTrigger" type="text" readonly />

            <label for="customCommandEditMediaType">Media Type</label>
            <select id="customCommandEditMediaType">
              <option value="none">No media</option>
              <% mediaTypes.forEach((type) => { %>
              <option value="<%= type %>"><%= type %></option>
              <% }) %>
            </select>

            <label for="customCommandEditMediaUrl">Media URL <span class="muted">(optional)</span></label>
            <input id="customCommandEditMediaUrl" type="text" placeholder="https://..." />

            <label for="customCommandEditFileName">File Name <span class="muted">(document only, optional)</span></label>
            <input id="customCommandEditFileName" type="text" placeholder="brochure.pdf" />

            <label for="customCommandEditResponse">Text Help</label>
            <textarea id="customCommandEditResponse" rows="4" placeholder="Reply message..."></textarea>

            <div class="command-detail-popover-actions command-detail-popover-inline-actions">
              <button type="button" class="btn btn-ghost btn-sm" id="customCommandEditAddButtonBtn">Add Button</button>
            </div>
            <div id="customCommandEditButtonRows" class="button-rows"></div>

            <p class="feedback" id="customCommandEditFeedback"></p>
          </div>
        </div>
        <footer class="schedule-modal-actions schedule-detail-footer">
          <button type="button" class="btn btn-outline" id="customCommandEditCancelBtn">Cancel</button>
          <button type="button" class="btn btn-outline" id="customCommandEditSaveBtn">Save</button>
        </footer>
      </div>
    </div>

    <div class="modal" id="buttonSetupGuideModal" hidden>
      <div class="modal-backdrop" data-close-modal="button-setup-guide"></div>
      <div class="modal-panel button-setup-guide-modal-panel" role="dialog" aria-modal="true" aria-labelledby="buttonSetupGuideModalTitle">
        <button type="button" class="modal-close" id="closeButtonSetupGuideModal" aria-label="Close button setup guide">&times;</button>
        <div class="card-content button-setup-guide-content">
          <h3 class="card-title" id="buttonSetupGuideModalTitle">Button Setup Guide</h3>
          <ul class="button-setup-guide-list">
            <li><strong>Quick Reply Button:</strong> The <strong>Value (id)</strong> MUST match an existing command trigger (example: <code>.hello</code>, <code>.menu1</code>).</li>
            <li><strong>Single Select:</strong> Each row ID must also match a command trigger.</li>
            <li><strong>Call Button:</strong> Enter phone number with country code (example: <a href="tel:60123456789">60123456789</a>).</li>
            <li><strong>Copy Code Button:</strong> Enter the code to copy (example: <code>PROMO2024</code>).</li>
          </ul>
          <p class="button-setup-guide-example"><strong>Example:</strong> If you create a command with trigger <strong>.hello</strong>, then add a Quick Reply button with Value = <strong>.hello</strong>. When user clicks the button, it will trigger the <strong>.hello</strong> command.</p>
          <p class="button-setup-guide-json">For JSON rows format: <code>[{"id":".cmd1","title":"Option 1"},{"id":".cmd2","title":"Option 2"}]</code></p>
          <div class="schedule-modal-actions">
            <button type="button" class="btn btn-outline" id="buttonSetupGuideModalCloseBtn">Close</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      window.__SCHEDULES__ = <%= JSON.stringify(schedules) %>;
      window.__CUSTOM_COMMANDS__ = <%= JSON.stringify(customCommands) %>;
      window.__CHAT_RESPONSE_SETTINGS__ = <%= JSON.stringify(chatResponseSettings) %>;
      window.__ACCESS_CONTROL_SETTINGS__ = <%= JSON.stringify(accessControlSettings) %>;
      window.__BUILT_IN_COMMAND_SETTINGS__ = <%= JSON.stringify(builtInCommandSettings) %>;
    </script>
    <script src="/public/app.js"></script>

    <!-- Deleted Message Viewer Modal -->
    <div class="dm-view-modal-backdrop" id="dmViewModalBackdrop" hidden aria-modal="true" role="dialog" aria-labelledby="dmViewModalTitle">
      <div class="dm-view-modal">
        <div class="dm-view-modal-header">
          <div class="dm-view-modal-identity">
            <div class="dm-view-modal-avatar" id="dmViewModalAvatar" aria-hidden="true">?</div>
            <div class="dm-view-modal-meta">
              <h3 class="dm-view-modal-title" id="dmViewModalTitle">Deleted Message</h3>
              <p class="dm-view-modal-subtitle" id="dmViewModalSubtitle"></p>
            </div>
          </div>
          <button type="button" class="btn btn-ghost btn-sm" id="dmViewModalClose" aria-label="Close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>

        <!-- Chat preview area -->
        <div class="dm-view-chat-area">
          <!-- Message bubble rendered by JS -->
          <div class="dm-view-bubble-wrap" id="dmViewBubbleWrap"></div>
        </div>

        <!-- Meta info below bubble -->
        <div class="dm-view-modal-footer">
          <div class="dm-view-meta-grid" id="dmViewMetaGrid"></div>
        </div>
      </div>
    </div>
  </body>
</html>
